                             font=("Segoe UI Mono", 10))
        yt_entry.grid(row=0, column=1, sticky="ew", padx=(0,12), ipady=4)
        tk.Label(card, text="🔗", bg=self.BG2, fg=self.ACCENT,
                 font=("Segoe UI",12)).grid(row=0, column=2, padx=2)

        # VM selector
