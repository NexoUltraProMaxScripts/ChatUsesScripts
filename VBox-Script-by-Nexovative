def start_overlay_server():
    PORT = 8083
    class QuietHandler(http.server.SimpleHTTPRequestHandler):
        def log_message(self, format, *args): pass
    try:
        with socketserver.TCPServer(("", PORT), QuietHandler) as httpd:
